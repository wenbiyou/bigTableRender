{
  "name": "big-table-render",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://wenbiyou.github.io/bigTableRender/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "check:fix": "npm run lint:fix && npm run format",
    "prepare": "husky",
    "clean": "rm -rf dist node_modules/.cache",
    "clean:all": "rm -rf dist node_modules",
    "deploy:verify": "node scripts/verify-deploy.js",
    "deploy:status": "curl -s -o /dev/null -w '%{http_code}' https://wenbiyou.github.io/bigTableRender/"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "antd": "^5.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "vite": "^5.0.0"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "prettier --write --ignore-path .prettierignore",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,html,css}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
