{
  "name": "big-table-render",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://wenbiyou.github.io/bigTableRender/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:staged": "lint-staged",
    
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    
    "check": "npm run lint && npm run format:check",
    "check:fix": "npm run lint:fix && npm run format",
    
    "commit": "git-cz",
    "prepare": "husky",
    
    "security": "npm audit",
    "security:fix": "npm audit fix",
    
    "clean": "rm -rf dist node_modules/.cache",
    "clean:all": "rm -rf dist node_modules",
    
    "deploy:verify": "node scripts/verify-deploy.js",
    "deploy:local": "npm run build && echo '构建完成，手动推送到 GitHub 触发部署'",
    "deploy:status": "curl -s -o /dev/null -w '%{http_code}' https://wenbiyou.github.io/bigTableRender/"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "antd": "^5.16.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    
    "prettier": "^3.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    
    "typescript": "^5.3.3",
    "@typescript-eslint/parser": "^7.1.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-path .prettierignore",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,html,css,scss,less,yaml,yml}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}