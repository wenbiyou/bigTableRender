#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 运行 pre-commit 钩子..."

# 1. 运行 lint-staged（自动格式化 + ESLint 检查）
echo "📝 运行 lint-staged (Prettier + ESLint)..."
npx lint-staged

# 2. 检查是否有未暂存的更改
if git diff --name-only | grep -q .; then
  echo "⚠️  检测到未暂存的更改，请重新提交"
  exit 1
fi

echo "✅ pre-commit 检查通过！"