#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "📝 运行 commit-msg 钩子..."

# 1. 验证 commit 信息格式
echo "🔍 验证 commit 信息格式..."
npx commitlint --edit "$1"

if [ $? -eq 0 ]; then
  echo "✅ commit 信息格式正确！"
else
  echo "❌ commit 信息格式错误，请参考以下格式："
  echo ""
  echo "格式: <type>(<scope>): <subject>"
  echo ""
  echo "类型 (type):"
  echo "  feat:     新功能"
  echo "  fix:      修复 bug"
  echo "  docs:     文档更新"
  echo "  style:    代码格式（不影响功能）"
  echo "  refactor: 代码重构"
  echo "  perf:     性能优化"
  echo "  test:     测试相关"
  echo "  build:    构建系统或外部依赖"
  echo "  ci:       CI 配置"
  echo "  chore:    其他修改"
  echo "  revert:   回退提交"
  echo ""
  echo "示例:"
  echo "  feat(component): 添加新的表格组件"
  echo "  fix(worker): 修复数据加载问题"
  echo "  docs(readme): 更新项目文档"
  echo ""
  exit 1
fi